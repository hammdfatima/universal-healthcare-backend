# Render sets PORT automatically; local dev can use PORT_NO instead
PORT_NO=8080
JWT_SECRET=replace-with-a-long-random-secret
# 32-byte key as base64: `openssl rand -base64 32`
PHI_ENCRYPTION_KEY=replace-with-32-byte-base64-key
# Set true only for local/dev API docs (/doc, /reference). Disabled in production by default.
ENABLE_API_DOCS=false
DATABASE_URL=postgresql://user:password@host-pooler:5432/dbname?sslmode=require&pgbouncer=true
# Direct (non-pooler) connection for Prisma migrations. On Neon, remove "-pooler" from the host.
# For local Postgres, set this to the same value as DATABASE_URL.
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://universal-healthcrae-frontend.onrender.com

RESEND_API_KEY=re_...

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional fallback for unsigned uploads when API secret is not available
CLOUDINARY_UPLOAD_PRESET=
