// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/zod"
  config   = "../zod.config.json"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  cancelled
  inactive
  past_due
  trialing
  incomplete
}

enum PaymentRecordStatus {
  paid
  pending
  failed
}

enum NotificationType {
  medication
  vaccination
  lab
  imaging
  provider
  system
}

model SubscriptionPlan {
  id                   String             @id @default(cuid())
  planName             String
  price                String
  billingCycle         BillingCycle       @default(monthly)
  features             String[]
  memberLimit          Int                @default(0)
  allowsPets           Boolean            @default(false)
  stripeProductId      String?            @unique
  stripePriceId        String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  subscriptions        UserSubscription[]
  scheduledForUsers    UserSubscription[] @relation("ScheduledSubscriptionPlan")
  payments             Payment[]
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  firstName           String?
  lastName            String?
  name                String?
  phone               String?
  profileImage        String?
  gender              String?
  dateOfBirth         String?
  bloodGroup          String?
  address             String?
  onboardingCompleted Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)
  managedByOwnerId    String?
  managedByOwner      User?     @relation("ManagedFamilyAccounts", fields: [managedByOwnerId], references: [id], onDelete: SetNull)
  isBlocked           Boolean   @default(false)
  tokenVersion        Int       @default(0)
  emailNotifications  Boolean   @default(true)
  inAppNotifications  Boolean   @default(true)
  password            String
  role                Role      @default(USER)
  emailVerified       Boolean   @default(false)
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  otps                    Otp[]
  passwordResetTokens     PasswordResetToken[]
  subscription            UserSubscription?
  managedFamilyAccounts   User[]         @relation("ManagedFamilyAccounts")
  ownedFamilyMembers      FamilyMember[] @relation("FamilyMemberOwner")
  familyMemberProfile     FamilyMember?  @relation("FamilyMemberAccount")
  ownedPets               Pet[]
  careProviders           CareProvider[]
  medications             Medication[]
  allergies               Allergy[]
  healthHistoryEntries      HealthHistoryEntry[]
  vaccinations              Vaccination[]
  labResults                LabResult[]
  imagingResults            ImagingResult[]
  payments                  Payment[]
  notifications             Notification[]
  repliedUserQueries        UserQuery[] @relation("UserQueryRepliedBy")
  emergencyAccessToken      EmergencyAccessToken?
  medicalRecordShareWithAll Boolean     @default(false)
  medicalRecordSharesOwned  MedicalRecordShare[] @relation("MedicalRecordShareOwner")
  medicalRecordSharesGranted MedicalRecordShare[] @relation("MedicalRecordShareGrantee")
}

model EmergencyAccessToken {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token             String    @unique
  pinHash           String
  expiresAt         DateTime
  failedPinAttempts Int       @default(0)
  lockedUntil       DateTime?
  isActive          Boolean   @default(true)
  lastAccessedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([token])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  actorRole     String?
  action        String
  resourceType  String
  resourceId    String?
  patientUserId String?
  ip            String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([patientUserId])
  @@index([action])
  @@index([resourceType])
}

model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlanId   String
  subscriptionPlan     SubscriptionPlan   @relation(fields: [subscriptionPlanId], references: [id])
  scheduledPlanId      String?
  scheduledPlan        SubscriptionPlan?  @relation("ScheduledSubscriptionPlan", fields: [scheduledPlanId], references: [id], onDelete: SetNull)
  scheduledPlanChangeAt DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(inactive)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([subscriptionPlanId])
  @@index([scheduledPlanId])
}

model Otp {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
}

model FamilyMember {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              User     @relation("FamilyMemberOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberUserId       String   @unique
  memberUser         User     @relation("FamilyMemberAccount", fields: [memberUserId], references: [id], onDelete: Cascade)
  relationship       String
  isEmergencyContact Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  petsAsEmergencyContact Pet[]

  @@index([ownerId])
}

model Pet {
  id                             String        @id @default(cuid())
  ownerId                        String
  owner                          User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name                           String
  species                        String
  breed                          String?
  sex                            String?
  color                          String?
  dateOfBirth                    String?
  microchipId                    String?
  veterinaryClinic               String?
  veterinaryPhone                String?
  veterinaryRecords              String?
  medicationsJson                String        @default("[]")
  allergiesJson                  String        @default("[]")
  vaccinationsJson               String        @default("[]")
  emergencyContactFamilyMemberId String?
  emergencyContactFamilyMember   FamilyMember? @relation(fields: [emergencyContactFamilyMemberId], references: [id], onDelete: SetNull)
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt

  @@index([ownerId])
  @@index([emergencyContactFamilyMemberId])
}

model MedicalRecordShare {
  id          String   @id @default(cuid())
  ownerUserId String
  ownerUser   User     @relation("MedicalRecordShareOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  granteeUserId String
  granteeUser User     @relation("MedicalRecordShareGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerUserId, granteeUserId])
  @@index([ownerUserId])
  @@index([granteeUserId])
}

model CareProvider {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  email         String?
  clinicDetails String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Medication {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicineName String
  condition    String
  prescribedBy String
  dosage       String
  timesPerDay  Int       @default(1)
  timesOfDay   String[]  @default([])
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Allergy {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergyType String
  nature      String
  symptoms    String[]
  triggers    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model HealthHistoryEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  illnessName   String
  diagnosisDate DateTime
  prescribedBy  String
  details       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Vaccination {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vaccineName    String
  prescribedBy   String
  administeredBy String
  dosage         String
  vaccinationDate DateTime
  time           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model LabResult {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  testType         String
  testDate         DateTime
  fileUrl          String
  filePublicId     String
  fileMimeType     String
  fileResourceType String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model ImagingResult {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  testType         String
  scanType         String
  scanDate         DateTime
  fileUrl          String
  filePublicId     String
  fileMimeType     String
  fileResourceType String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id                      String              @id @default(cuid())
  userId                  String
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlanId      String?
  subscriptionPlan        SubscriptionPlan?   @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  invoiceNumber           String              @unique
  stripeInvoiceId         String?             @unique
  stripeCheckoutSessionId String?             @unique
  amountCents             Int
  currency                String              @default("usd")
  status                  PaymentRecordStatus
  billingCycle            String
  paymentMethod           String?
  transactionId           String?
  paidAt                  DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paidAt])
}

model UserQuery {
  id          String    @id @default(cuid())
  fullName    String
  email       String
  subject     String
  message     String
  isResolved  Boolean   @default(false)
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  repliedBy   User?     @relation("UserQueryRepliedBy", fields: [repliedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isResolved])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  href      String?
  read      Boolean          @default(false)
  dedupeKey String?
  createdAt DateTime         @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId, read])
  @@index([userId, createdAt])
}
